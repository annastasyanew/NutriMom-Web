{
    "system_name": "NutriMom",
    "system_type": "Hybrid Decision Support System",
    "methods": [
        "XGBoost",
        "Fuzzy Logic",
        "Simple Additive Weighting"
    ],
    "description": "Rekomendasi makanan sehat ibu hamil berbasis prediksi risiko maternal, fuzzy risk scoring, dan ranking makanan menggunakan SAW.",
    "maternal_dataset_path": "/content/drive/MyDrive/SEMESTER 6/SKP/Dataset/MaternalData.csv",
    "food_dataset": "comprehensive_foods_usda.csv",
    "ai_module": {
        "method": "XGBoost",
        "task": "Maternal risk classification",
        "features": [
            "Age",
            "SystolicBP",
            "DiastolicBP",
            "BS",
            "BodyTemp",
            "BMI",
            "PreviousComplications",
            "PreexistingDiabetes",
            "GestationalDiabetes",
            "MentalHealth",
            "HeartRate"
        ],
        "classes": [
            "Low Risk",
            "High Risk"
        ],
        "metrics": {
            "accuracy": 0.9829059829059829,
            "f1_macro": 0.9822188449848024,
            "roc_auc": 0.9994698977659977,
            "pr_auc": 0.9992273777689556
        }
    },
    "fuzzy_module": {
        "task": "Maternal risk scoring",
        "outputs": [
            "age_risk",
            "bp_risk",
            "glucose_risk",
            "bmi_risk",
            "temperature_risk",
            "heart_rate_risk",
            "complication_risk",
            "mental_health_risk"
        ]
    },
    "spk_module": {
        "method": "Simple Additive Weighting",
        "task": "Food recommendation ranking",
        "food_criteria": [
            "protein_g",
            "fiber_g",
            "iron_mg",
            "calcium_mg",
            "sugar_g",
            "sodium_mg",
            "calories"
        ],
        "note": "Bobot makanan bersifat adaptif berdasarkan fuzzy risk score."
    },
    "output": [
        "ai_prediction",
        "ai_confidence",
        "class_probabilities",
        "fuzzy_scores",
        "dominant_risk_factors",
        "food_weights",
        "top_foods",
        "final_recommendation"
    ],
    "disclaimer": "Sistem ini hanya alat bantu edukatif dan tidak menggantikan konsultasi dokter atau ahli gizi."
}